      "source": [
        "# 商品購入時の消費税を出す関数を作成(110円に消費税10％を加えた金額を出す関数)\n",
        "# 変数price = 商品の金額110\n",
        "# 変数tax = 消費税% 10\n",
        "def total_price(price:int,tax:int) -> int :\n",
        "  total = price * (1 + (tax / 100))\n",
        "\n",
        "  return total\n",
        "\n",
        "total_price(110,10)\n"
      ]
    }
  ]
